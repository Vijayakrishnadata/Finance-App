      <select class="inp" id="f-cat" onchange="updateSubcats()" style="appearance:none">
        <option value="">Select category</option>${catOpts}
      </select>
    </div>
    <div class="fld" id="subcat-fld" style="${subOpts?'':'display:none'}"><label>Sub-category</label>
      <select class="inp" id="f-sub" style="appearance:none">
        <option value="">Select sub-category</option>${subOpts}
      </select>
    </div>
    <div class="fld"><label>Ledger</label>
      <select class="inp" id="f-ledger" style="appearance:none">
        <option value="">Select ledger</option>${ledOpts}
      </select>
    </div>
    <div class="fld"><label>Tags (comma-separated)</label><input class="inp" id="f-tags" placeholder="sales, fixed, recurring…" value="${esc(tagsVal)}"/></div>
    <button class="btn-primary" onclick="saveTx()" style="margin-top:8px">${tx?'Update Entry':'Add Entry'}</button>
  `);
}

function toggleType(btn, type) {
  document.querySelectorAll('.type-btn').forEach(b => { b.className = 'type-btn'; });
  btn.className = `type-btn active-${type}`;
  document.getElementById('f-type').value = type;
}

function updateSubcats() {
  const catId = document.getElementById('f-cat').value;
  const subs = App.data.subcategories.filter(s=>s.categoryId===catId);
  const fld = document.getElementById('subcat-fld');
  const sel = document.getElementById('f-sub');
  if (subs.length) {
    fld.style.display = '';
    sel.innerHTML = '<option value="">Select sub-category</option>' + subs.map(s=>`<option value="${esc(s.id)}">${esc(s.name)}</option>`).join('');
  } else { fld.style.display = 'none'; }
}

async function saveTx() {
  const id   = document.getElementById('f-id').value;
  const type = document.getElementById('f-type').value;
  const date = document.getElementById('f-date').value;
  const desc = document.getElementById('f-desc').value.trim();
  const amt  = parseFloat(document.getElementById('f-amount').value);
  const cat  = document.getElementById('f-cat').value;
  const sub  = document.getElementById('f-sub') ? document.getElementById('f-sub').value : '';
  const led  = document.getElementById('f-ledger').value;
  const tags = document.getElementById('f-tags').value;

  if (!desc || !amt || !date) { showToast('Fill in required fields', 'error'); return; }

  const t = { id:id||uid(), date, type, description:desc, amount:amt, categoryId:cat, subcategoryId:sub, ledgerId:led, tags };
  const btn = document.querySelector('#modalBody .btn-primary');
  btn.textContent = 'Saving…'; btn.disabled = true;

  if (id) {
    App.data.transactions = App.data.transactions.map(x => x.id===id?t:x);
    await api('update', { sheet:'Transactions', id, row:{...t,tags:t.tags} });
    showToast('Updated in Google Sheets ✓');
  } else {
    App.data.transactions = [t, ...App.data.transactions];
    await api('add', { sheet:'Transactions', row:{...t,tags:t.tags} });
    showToast('Saved to Google Sheets ✓');
  }
  closeModal();
  renderTransactions();
  document.getElementById('sheetsStatus').textContent = `Google Sheets · ${App.data.transactions.length} entries`;
}

async function deleteTx(id) {
  if (!confirm('Delete this entry?')) return;
  App.data.transactions = App.data.transactions.filter(t=>t.id!==id);
  await api('delete', { sheet:'Transactions', id });
  showToast('Deleted ✓');
  renderTransactions();
}

/* ═══════════════════════════════════════════════════════════════
   IMPORT
═══════════════════════════════════════════════════════════════ */
async function handleImport(e) {
  const file = e.target.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = async ev => {
    try {
      const wb = XLSX.read(ev.target.result, {type:'binary'});
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws);
      let count = 0;
      for (const r of rows) {
        const t = {
          id:uid(),
          date:String(r.Date||r.date||new Date().toISOString().slice(0,10)).slice(0,10),
          type:(r.Type||r.type||'expense').toLowerCase(),
          description:String(r.Description||r.description||r.Narration||'Imported'),
          amount:parseFloat(r.Amount||r.amount||0),
          categoryId:'', subcategoryId:'', ledgerId:'', tags:'imported'
        };
        App.data.transactions.push(t);
        await api('add', { sheet:'Transactions', row:t });
        count++;
      }
      showToast(`Imported ${count} entries ✓`);
      renderTransactions();
    } catch(err) { showToast('Parse error. Expected: Date, Type, Description, Amount', 'error'); }
    e.target.value = '';
  };
  reader.readAsBinaryString(file);
}

