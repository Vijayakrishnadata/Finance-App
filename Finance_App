═══════════════════════════════════════════════════════════════ */
const STEPS = [
  { title:'Create a Google Sheet', body:'Go to sheets.google.com → click Blank spreadsheet.\nName it anything (e.g. "My Finance DB").' },
  { title:'Open Apps Script Editor', body:'In the Google Sheet:\nExtensions → Apps Script\nA code editor tab will open.' },
  { title:'Paste the Script', body:'Select all code (Ctrl+A), delete it, then click "Copy Script" above and paste it.\nSave with Ctrl+S.' },
  { title:'Deploy as Web App', body:'Click Deploy → New Deployment → select type: Web App.\nSet:\n  Execute as: Me\n  Who has access: Anyone\nClick Deploy → copy the Web App URL.' },
  { title:'Paste URL & Connect', body:'Paste the Web App URL in the field below.\nClick "Connect to Google Sheets".' },
];

function initSetupSteps() {
  let stepOpen = 0;
  const list = document.getElementById('steps-list');
  function render() {
    list.innerHTML = STEPS.map((s,i) => `
      <div class="step-item ${stepOpen===i?'open':''}" onclick="setStep(${i})">
        <div class="step-num">${i+1}</div>
        <div>
          <div class="step-title">${s.title}</div>
          <div class="step-body">${s.body}</div>
        </div>
      </div>
    `).join('');
  }
  window.setStep = i => { stepOpen = stepOpen===i?-1:i; render(); };
  render();
}

function copyScript() {
  navigator.clipboard.writeText(GAS_CODE).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.className = 'copy-btn copied';
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copied!`;
    setTimeout(() => {
      btn.className = 'copy-btn default';
      btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy Script`;
    }, 2500);
  });
}

