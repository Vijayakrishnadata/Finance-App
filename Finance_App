/* ═══════════════════════════════════════════════════════════════
   TRANSACTIONS
═══════════════════════════════════════════════════════════════ */
function renderTransactions() {
  const { transactions, categories } = App.data;
  const filtered = transactions
    .filter(t => (App.txFilter==='all'||t.type===App.txFilter) && t.description.toLowerCase().includes(App.txSearch.toLowerCase()))
    .sort((a,b) => b.date.localeCompare(a.date));

  // Group by date
  const groups = {};
  filtered.forEach(t => { if(!groups[t.date]) groups[t.date]=[]; groups[t.date].push(t); });

  let listHtml = '';
  Object.entries(groups).forEach(([date, txs]) => {
    listHtml += `<div class="tx-group-label">${date}</div><div class="tx-list">`;
    txs.forEach(t => {
      const cat = categories.find(c=>c.id===t.categoryId);
      const tags = toArr(t.tags);
      const isInc = t.type==='income';
      listHtml += `<div class="tx-item">
        <div class="tx-icon" style="background:${isInc?'var(--green-dim)':'var(--red-dim)'};color:${isInc?'var(--green)':'var(--red)'}">
          ${isInc?svgUp:svgDown}
        </div>
        <div class="tx-info">
          <div class="tx-name">${esc(t.description)}</div>
          <div class="tx-meta">${cat?esc(cat.name):'—'}${tags.length?' · '+tags.slice(0,2).join(', '):''}</div>
        </div>
        <div>
          <div class="tx-amount" style="color:${isInc?'var(--green)':'var(--red)'}">${isInc?'+':'-'}${fmt(+t.amount)}</div>
          <div class="tx-actions">
            <button onclick="openTxForm('${esc(t.id)}')" title="Edit">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </button>
            <button onclick="deleteTx('${esc(t.id)}')" title="Delete">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
      </div>`;
    });
    listHtml += '</div>';
  });

  if (!filtered.length) {
    listHtml = `<div class="empty-state"><div class="empty-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div><p>No transactions found</p></div>`;
  }

  document.getElementById('page-transactions').innerHTML = `
    <div style="display:flex;gap:8px;margin-bottom:12px">
      <div class="search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="inp" placeholder="Search transactions…" value="${esc(App.txSearch)}" oninput="App.txSearch=this.value;renderTransactions()" style="padding-left:38px"/>
      </div>
      <button class="btn-secondary" onclick="document.getElementById('importFile').click()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Import
      </button>
    </div>
    <div class="filter-row">
      <button class="filter-pill ${App.txFilter==='all'?'active-all':''}" onclick="App.txFilter='all';renderTransactions()">All</button>
      <button class="filter-pill ${App.txFilter==='income'?'active-income':''}" onclick="App.txFilter='income';renderTransactions()">Income</button>
      <button class="filter-pill ${App.txFilter==='expense'?'active-expense':''}" onclick="App.txFilter='expense';renderTransactions()">Expense</button>
    </div>
    ${listHtml}
    <button class="fab" onclick="openTxForm(null)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>
  `;
}

