    <input type="hidden" id="f-type" value="${esc(f.type)}"/>
    <div class="fld"><label>Date</label><input class="inp" type="date" id="f-date" value="${esc(f.date)}"/></div>
    <div class="fld"><label>Description</label><input class="inp" id="f-desc" placeholder="What was this for?" value="${esc(f.description)}"/></div>
    <div class="fld"><label>Amount (₹)</label><input class="inp" type="number" id="f-amount" placeholder="0" value="${esc(f.amount||'')}"/></div>
