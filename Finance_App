async function saveMaster() {
  const tab = App.masterTab;
  const name = document.getElementById('m-name').value.trim();
  if (!name) { showToast('Enter a name','error'); return; }
  const btn = document.querySelector('#modalBody .btn-primary');
  btn.textContent='Saving…';btn.disabled=true;

  if (tab === 'groups') {
    const type = document.getElementById('m-type').value;
    if (!type) { showToast('Select a type','error'); btn.textContent='Create';btn.disabled=false; return; }
    const g = {id:uid(),name,type};
    App.data.groups.push(g);
    await api('add',{sheet:'Groups',row:g});
    showToast('Group saved ✓');
  } else if (tab === 'categories') {
    const groupId = document.getElementById('m-group').value;
    if (!groupId) { showToast('Select a group','error'); btn.textContent='Create';btn.disabled=false; return; }
    const c = {id:uid(),name,groupId};
    App.data.categories.push(c);
    await api('add',{sheet:'Categories',row:c});
    showToast('Category saved ✓');
  } else {
    const categoryId = document.getElementById('m-cat').value;
    if (!categoryId) { showToast('Select a category','error'); btn.textContent='Create';btn.disabled=false; return; }
    const s = {id:uid(),name,categoryId};
    App.data.subcategories.push(s);
    await api('add',{sheet:'SubCategories',row:s});
    showToast('Sub-category saved ✓');
  }
  closeModal(); renderSettings();
}

async function deleteMaster(sheet, id) {
  if (!confirm('Delete this item?')) return;
  if (sheet==='Groups') App.data.groups = App.data.groups.filter(x=>x.id!==id);
  if (sheet==='Categories') App.data.categories = App.data.categories.filter(x=>x.id!==id);
  if (sheet==='SubCategories') App.data.subcategories = App.data.subcategories.filter(x=>x.id!==id);
  await api('delete',{sheet,id});
  renderSettings();
}

/* ═══════════════════════════════════════════════════════════════
