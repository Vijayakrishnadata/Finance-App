window.addEventListener('DOMContentLoaded', () => {
  initSetupSteps();
  document.getElementById('pageDate').textContent = new Date().toDateString();
  if (App.gasUrl) {
    loadData(App.gasUrl);
  } else {
    showScreen('setup');
  }
});
