<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>FinanceOS — Smart Money Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root {
    --bg: #05090F;
    --bg2: #0A1020;
    --card: #0D1526;
    --card2: #111C30;
    --border: rgba(255,255,255,0.07);
    --accent: #4F8EF7;
    --accent-dim: rgba(79,142,247,0.12);
    --green: #2DD4A0;
    --green-dim: rgba(45,212,160,0.10);
    --red: #F4716A;
    --red-dim: rgba(244,113,106,0.10);
    --text: #EEF2FF;
    --text2: #94A3B8;
    --muted: #3D5070;
    --font-head: 'Syne', sans-serif;
    --font-body: 'Manrope', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font-body); -webkit-tap-highlight-color: transparent; overscroll-behavior: none; }
  input, select, button, textarea { font-family: var(--font-body); }
  ::-webkit-scrollbar { width: 0; height: 0; }
  input::placeholder { color: var(--muted); }
  select option { background: var(--card); color: var(--text); }
  input[type=date]::-webkit-calendar-picker-indicator { filter: invert(0.4); }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
  @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
  @keyframes toastIn { from { opacity:0; transform:translateX(-50%) translateY(-8px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }

  /* ── LAYOUT ── */
  #app { max-width: 430px; margin: 0 auto; min-height: 100vh; position: relative; }

  /* ── HEADER ── */
  .header {
    position: sticky; top: 0; z-index: 90;
    background: rgba(5,9,15,0.95);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 14px 20px 10px;
  }
  .header-row { display: flex; justify-content: space-between; align-items: center; }
  .header-title { font-family: var(--font-head); font-size: 20px; font-weight: 800; color: var(--text); letter-spacing: -0.4px; }
  .header-sub { font-size: 10px; color: var(--muted); margin-top: 1px; font-family: var(--font-mono); }
  .header-actions { display: flex; align-items: center; gap: 8px; }
  .header-badge { display: flex; align-items: center; gap: 5px; margin-top: 6px; }
  .header-badge span { font-size: 10px; color: var(--muted); font-family: var(--font-mono); }
  .icon-btn { width: 34px; height: 34px; border-radius: 9px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
  .sync-indicator { width: 18px; height: 18px; color: var(--accent); animation: spin 1s linear infinite; display: none; }
  .sync-indicator.active { display: block; }
  .logo-btn { width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(135deg,#4F8EF7,#2DD4A0); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-family: var(--font-head); font-weight: 800; color: #fff; font-size: 14px; }

  /* ── BOTTOM NAV ── */
  .bottom-nav {
    position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 100%; max-width: 430px; z-index: 200;
    background: rgba(5,9,15,0.97); backdrop-filter: blur(20px);
    border-top: 1px solid var(--border);
    display: flex; padding: 8px 0 22px;
  }
  .nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px 0; }
  .nav-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; color: var(--muted); }
  .nav-item.active .nav-icon { background: var(--accent-dim); color: var(--accent); }
  .nav-label { font-size: 10px; font-weight: 700; color: var(--muted); letter-spacing: 0.04em; transition: color 0.15s; }
  .nav-item.active .nav-label { color: var(--accent); }

  /* ── PAGE ── */
  .page { padding: 12px 16px 110px; animation: fadeUp 0.25s ease; display: none; }
  .page.active { display: block; }

  /* ── CARDS ── */
  .card { background: var(--card); border-radius: 16px; border: 1px solid var(--border); }
  .card-p { padding: 16px; }

  /* ── HERO P&L ── */
  .hero-card {
    background: linear-gradient(135deg,#070F1E,#0C1930);
    border-radius: 20px; padding: 20px; margin-bottom: 14px;
    border: 1px solid rgba(79,142,247,0.15);
    position: relative; overflow: hidden;
  }
  .hero-card::before {
    content:''; position:absolute; right:-30px; top:-30px;
    width:130px; height:130px; border-radius:50%;
    background: rgba(79,142,247,0.07);
  }
  .hero-label { font-size: 10px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; margin-bottom: 4px; }
  .hero-amount { font-family: var(--font-mono); font-size: 34px; font-weight: 600; letter-spacing: -1px; margin-bottom: 14px; }
  .hero-row { display: flex; gap: 24px; }
  .hero-stat-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; margin-bottom: 2px; }
  .hero-stat-val { font-family: var(--font-mono); font-size: 18px; font-weight: 600; color: var(--text); }

  /* ── 2-COL GRID ── */
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .stat-card { border-radius: 16px; padding: 14px; border: 1px solid; }
  .stat-card-label { font-size: 9px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; margin: 8px 0 2px; }
  .stat-card-val { font-family: var(--font-mono); font-size: 20px; font-weight: 600; }

  /* ── BAR CHART ── */
  .chart-wrap { display: flex; align-items: flex-end; gap: 5px; height: 72px; }
  .chart-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .chart-bars { display: flex; gap: 2px; align-items: flex-end; height: 56px; }
  .bar { width: 8px; border-radius: 3px 3px 0 0; min-height: 2px; transition: height 0.4s; }
  .chart-label { font-size: 9px; color: var(--muted); font-family: var(--font-mono); }

  /* ── SECTION TITLE ── */
  .section-title { font-family: var(--font-head); font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 12px; }
  .group-label { font-size: 11px; color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }

  /* ── PROGRESS BAR ── */
  .prog-track { height: 5px; background: rgba(255,255,255,0.06); border-radius: 99px; }
  .prog-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg,#4F8EF7,#7B6EF7); transition: width 0.5s; }

  /* ── TABLE ── */
  .data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .data-table th { text-align: left; padding: 5px 4px; color: var(--muted); font-weight: 700; border-bottom: 1px solid var(--border); letter-spacing: 0.04em; }
  .data-table th.r, .data-table td.r { text-align: right; }
  .data-table td { padding: 8px 4px; font-family: var(--font-mono); }

  /* ── TX LIST ── */
  .tx-group-label { font-size: 11px; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .tx-list { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); margin-bottom: 16px; }
  .tx-item { display: flex; align-items: center; padding: 12px 14px; background: var(--card); border-bottom: 1px solid var(--border); }
  .tx-item:last-child { border-bottom: none; }
  .tx-icon { width: 36px; height: 36px; border-radius: 9px; display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0; }
  .tx-info { flex: 1; min-width: 0; }
  .tx-name { font-size: 14px; color: var(--text); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }
  .tx-meta { font-size: 11px; color: var(--muted); }
  .tx-amount { font-family: var(--font-mono); font-size: 15px; font-weight: 600; margin-bottom: 4px; text-align: right; }
  .tx-actions { display: flex; gap: 6px; justify-content: flex-end; }
  .tx-actions button { background: none; border: none; color: #3D5070; cursor: pointer; padding: 2px; }

  /* ── FILTERS ── */
  .filter-row { display: flex; gap: 8px; margin-bottom: 14px; }
  .filter-pill { padding: 6px 16px; border-radius: 99px; border: none; cursor: pointer; font-size: 12px; font-weight: 700; text-transform: capitalize; font-family: var(--font-body); transition: all 0.15s; background: rgba(255,255,255,0.05); color: var(--muted); }
  .filter-pill.active-all { background: var(--accent); color: #fff; }
  .filter-pill.active-income { background: var(--green); color: #0a1020; }
  .filter-pill.active-expense { background: var(--red); color: #fff; }

  /* ── SEARCH ── */
  .search-wrap { position: relative; flex: 1; }
  .search-wrap svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); }
  .search-wrap input { padding-left: 38px; }

  /* ── INPUT / SELECT ── */
  .inp {
    width: 100%; padding: 11px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border); border-radius: 10px;
    color: var(--text); font-size: 14px; outline: none;
    font-family: var(--font-body);
    transition: border-color 0.15s;
  }
  .inp:focus { border-color: rgba(79,142,247,0.4); }
  .fld { margin-bottom: 14px; }
  .fld label { display: block; font-size: 11px; color: var(--muted); font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 5px; }

  /* ── BUTTONS ── */
  .btn-primary {
    width: 100%; padding: 13px 0;
    background: linear-gradient(135deg,#4F8EF7,#7B6EF7);
    border: none; border-radius: 11px; color: #fff;
    font-weight: 700; font-size: 15px; cursor: pointer;
    font-family: var(--font-head); letter-spacing: 0.02em;
    transition: opacity 0.15s;
  }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-secondary {
    padding: 10px 18px;
    background: var(--accent-dim);
    border: 1px solid rgba(79,142,247,0.3);
    border-radius: 10px; color: var(--accent);
    font-weight: 700; font-size: 13px; cursor: pointer;
    font-family: var(--font-body); display: flex; align-items: center; gap: 6px;
    transition: all 0.15s;
  }
  .btn-icon { background: none; border: none; cursor: pointer; }

  /* ── FAB ── */
  .fab {
    position: fixed; bottom: 88px; right: 20px;
    width: 56px; height: 56px; border-radius: 50%;
    background: linear-gradient(135deg,#4F8EF7,#7B6EF7);
    border: none; color: #fff; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 24px rgba(79,142,247,0.45); z-index: 100;
    transition: transform 0.15s;
  }
  .fab:active { transform: scale(0.93); }

  /* ── MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.75);
    z-index: 1000; display: flex; align-items: flex-end;
    backdrop-filter: blur(6px);
  }
  .modal-box {
    width: 100%; max-height: 92vh; background: var(--card);
    border-radius: 20px 20px 0 0; display: flex; flex-direction: column;
    border: 1px solid var(--border); overflow: hidden;
    animation: slideUp 0.25s cubic-bezier(0.32,0.72,0,1);
  }
  .modal-head { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid var(--border); }
  .modal-title { font-family: var(--font-head); font-size: 16px; font-weight: 700; color: var(--text); }
  .modal-close { background: rgba(255,255,255,0.06); border: none; color: var(--text2); border-radius: 8px; width: 32px; height: 32px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .modal-body { overflow-y: auto; flex: 1; padding: 16px 20px 36px; }

  /* ── TYPE TOGGLE ── */
  .type-toggle { display: flex; gap: 8px; margin-bottom: 16px; }
  .type-btn { flex: 1; padding: 10px 0; border-radius: 10px; border: none; cursor: pointer; font-weight: 700; font-size: 13px; font-family: var(--font-body); transition: all 0.15s; background: rgba(255,255,255,0.05); color: var(--muted); }
  .type-btn.active-income { background: var(--green); color: #0a1020; }
  .type-btn.active-expense { background: var(--red); color: #fff; }

  /* ── TAB BAR ── */
  .tab-bar { display: flex; gap: 6px; margin-bottom: 16px; background: rgba(255,255,255,0.04); border-radius: 12px; padding: 4px; }
  .tab-btn { flex: 1; padding: 8px 0; border-radius: 9px; border: none; cursor: pointer; font-size: 11px; font-weight: 700; text-transform: capitalize; font-family: var(--font-body); transition: all 0.15s; background: transparent; color: var(--muted); }
  .tab-btn.active { background: rgba(79,142,247,0.7); color: #fff; }

  /* ── LEDGER ITEM ── */
  .ledger-item { display: flex; align-items: center; padding: 14px; background: var(--card); border-bottom: 1px solid var(--border); }
  .ledger-item:last-child { border-bottom: none; }
  .ledger-icon { width: 36px; height: 36px; border-radius: 9px; background: var(--accent-dim); display: flex; align-items: center; justify-content: center; margin-right: 12px; flex-shrink: 0; color: var(--accent); }

  /* ── MASTER ITEM ── */
  .master-item { display: flex; align-items: center; padding: 12px 14px; background: var(--card); border-radius: 12px; margin-bottom: 8px; border: 1px solid var(--border); }

  /* ── SETUP ── */
  .setup-wrap { padding: 28px 20px 60px; }
  .setup-logo { width: 64px; height: 64px; border-radius: 18px; background: linear-gradient(135deg,#4F8EF7,#2DD4A0); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; color: #fff; }
  .setup-title { font-family: var(--font-head); font-size: 22px; font-weight: 800; color: var(--text); text-align: center; letter-spacing: -0.5px; }
  .setup-sub { font-size: 13px; color: var(--muted); text-align: center; margin-top: 6px; margin-bottom: 24px; }
  .code-box { background: #070D1A; border-radius: 14px; overflow: hidden; border: 1px solid var(--border); margin-bottom: 20px; }
  .code-head { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); background: rgba(0,0,0,0.3); }
  .code-label { font-size: 11px; font-weight: 700; color: var(--muted); font-family: var(--font-mono); }
  .copy-btn { display: flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; font-family: var(--font-body); transition: all 0.15s; }
  .copy-btn.default { background: var(--accent-dim); border: 1px solid rgba(79,142,247,0.3); color: var(--accent); }
  .copy-btn.copied { background: var(--green-dim); border: 1px solid rgba(45,212,160,0.4); color: var(--green); }
  .code-pre { margin: 0; padding: 12px 14px; font-size: 10px; color: #7C8FAC; font-family: var(--font-mono); overflow-x: auto; max-height: 150px; line-height: 1.6; white-space: pre-wrap; }
  .step-item { display: flex; gap: 12px; padding: 12px 14px; background: var(--card); border-radius: 12px; margin-bottom: 8px; border: 1px solid var(--border); cursor: pointer; transition: all 0.15s; }
  .step-item.open { background: var(--accent-dim); border-color: rgba(79,142,247,0.35); }
  .step-num { width: 26px; height: 26px; border-radius: 50%; background: rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 12px; font-weight: 700; color: var(--muted); transition: all 0.15s; }
  .step-item.open .step-num { background: rgba(79,142,247,0.7); color: #fff; }
  .step-title { font-size: 13px; font-weight: 700; color: #94a3b8; }
  .step-item.open .step-title { color: var(--text); }
  .step-body { font-size: 12px; color: var(--muted); line-height: 1.55; white-space: pre-line; margin-top: 4px; display: none; }
  .step-item.open .step-body { display: block; }
  .warn-box { background: rgba(251,191,36,0.07); border: 1px solid rgba(251,191,36,0.22); border-radius: 12px; padding: 12px 14px; margin-bottom: 18px; display: flex; gap: 10px; align-items: flex-start; }
  .warn-text { font-size: 12px; color: #D97706; line-height: 1.55; }
  .badge-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; justify-content: center; }
  .badge { font-size: 11px; color: var(--muted); padding: 4px 10px; border: 1px solid var(--border); border-radius: 99px; }
  .url-mono { font-family: var(--font-mono); font-size: 11px; }

  /* ── TOAST ── */
  .toast { position: fixed; top: 80px; left: 50%; transform: translateX(-50%); padding: 10px 20px; border-radius: 99px; font-size: 13px; font-weight: 700; z-index: 2000; box-shadow: 0 4px 20px rgba(0,0,0,0.4); white-space: nowrap; display: none; animation: toastIn 0.2s ease; }
  .toast.show { display: block; }
  .toast.success { background: var(--green); color: #0a1020; }
  .toast.error { background: var(--red); color: #fff; }

  /* ── LOADING / ERROR ── */
  .fullscreen { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; padding: 24px; }
  .spin-logo { width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(135deg,#4F8EF7,#2DD4A0); display: flex; align-items: center; justify-content: center; color: #fff; animation: spin 2s linear infinite; }
  .empty-state { text-align: center; padding: 48px 0; color: var(--muted); }
  .empty-icon { opacity: 0.25; margin-bottom: 12px; }

  /* ── IMPORT PREVIEW ── */
  .import-sample { margin-top: 18px; padding: 14px; background: rgba(79,142,247,0.06); border-radius: 10px; border: 1px solid rgba(79,142,247,0.2); }
  .import-table { width: 100%; font-size: 11px; color: var(--muted); border-collapse: collapse; }
  .import-table th { text-align: left; padding: 3px 6px; color: #64748b; }
  .import-table td { padding: 3px 6px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 430px) {
    .hero-amount { font-size: 28px; }
    .stat-card-val { font-size: 18px; }
  }
</style>
</head>
<body>
<div id="app">

  <!-- ═══ TOAST ═══ -->
  <div class="toast" id="toast"></div>

  <!-- ═══ SETUP SCREEN ═══ -->
  <div id="screen-setup" style="display:none">
    <div class="setup-wrap">
      <div class="setup-logo">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="2" y1="15" x2="22" y2="15"/><line x1="8" y1="3" x2="8" y2="21"/></svg>
      </div>
      <div class="setup-title">Connect Google Sheets</div>
      <div class="setup-sub">Your data lives in your own Google Drive — private, free &amp; unlimited rows.</div>

      <!-- Code Box -->
      <div class="code-box">
        <div class="code-head">
          <span class="code-label">Apps Script — Paste this in your Sheet</span>
          <button class="copy-btn default" id="copyBtn" onclick="copyScript()">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copy Script
          </button>
        </div>
        <pre class="code-pre">// ═══ Finance App — Google Apps Script Backend ═══
// Deploy: Deploy → New Deployment → Web App
// Execute as: Me  |  Access: Anyone

const SCHEMAS = {
  Transactions:  ['id','date','type','description','amount',
                  'categoryId','subcategoryId','ledgerId','tags'],
  Groups:        ['id','name','type'],
  Categories:    ['id','groupId','name'],
  SubCategories: ['id','categoryId','name'],
  Ledgers:       ['id','name','groupId','openingBalance']
};
// ... (copy full script via button above)</pre>
      </div>

      <!-- Steps -->
      <div style="margin-bottom:20px">
        <div class="group-label" style="margin-bottom:10px">Setup Steps</div>
        <div id="steps-list"></div>
      </div>

      <!-- Warning -->
      <div class="warn-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FBBF24" stroke-width="2" style="flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <p class="warn-text"><strong>Important:</strong> Set <strong>Execute as: Me</strong> and <strong>Who has access: Anyone</strong> when deploying. Without this the app cannot write to your sheet.</p>
      </div>

      <!-- URL -->
      <div class="fld">
        <label>Web App URL</label>
        <input class="inp url-mono" id="gasUrlInput" placeholder="https://script.google.com/macros/s/AKfy…/exec" />
      </div>
