<script>
/* ═══════════════════════════════════════════════════════════════
   APPS SCRIPT BACKEND CODE (full)
═══════════════════════════════════════════════════════════════ */
const GAS_CODE = `// ═══ Finance App — Google Apps Script Backend ═══
// 1. In Google Sheets: Extensions → Apps Script
// 2. Paste this entire code, save (Ctrl+S)
// 3. Deploy → New Deployment → Web App
//    Execute as: Me  |  Access: Anyone
// 4. Copy the Web App URL and paste in the app

const SCHEMAS = {
  Transactions:  ['id','date','type','description','amount','categoryId','subcategoryId','ledgerId','tags'],
  Groups:        ['id','name','type'],
  Categories:    ['id','groupId','name'],
  SubCategories: ['id','categoryId','name'],
  Ledgers:       ['id','name','groupId','openingBalance']
};

function doGet(e)  { return respond(route(e.parameter, null)); }
function doPost(e) { return respond(route(null, JSON.parse(e.postData.contents))); }

function respond(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

function route(p, b) {
  try {
    const a = (p && p.action) || (b && b.action);
    if (a === 'getAll') return getAll();
    if (a === 'init')   return initSheets();
    if (a === 'add')    return addRow(b.sheet, b.row);
    if (a === 'update') return updateRow(b.sheet, b.id, b.row);
    if (a === 'delete') return deleteRow(b.sheet, b.id);
    return { error: 'Unknown action: ' + a };
  } catch(e) { return { error: e.toString() }; }
}

function getAll() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const out = {};
  Object.keys(SCHEMAS).forEach(name => {
    const sh = ss.getSheetByName(name);
    if (!sh || sh.getLastRow() < 2) { out[name] = []; return; }
    const rows = sh.getDataRange().getValues();
    const hdrs = rows[0];
    out[name] = rows.slice(1)
      .filter(r => r[0])
      .map(r => Object.fromEntries(hdrs.map((h,i) => [h, r[i] ?? ''])));
  });
  return out;
}

function initSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  Object.entries(SCHEMAS).forEach(([name, hdrs]) => {
    let sh = ss.getSheetByName(name);
    if (!sh) sh = ss.insertSheet(name);
    if (sh.getLastRow() === 0) sh.appendRow(hdrs);
  });
  return { success: true };
}

function addRow(sheetName, row) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(sheetName);
  if (!sh) return { error: 'Sheet not found: ' + sheetName };
  const hdrs = sh.getRange(1,1,1,sh.getLastColumn()).getValues()[0];
  sh.appendRow(hdrs.map(h => row[h] !== undefined ? row[h] : ''));
  return { success: true };
}

function updateRow(sheetName, id, row) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(sheetName);
  if (!sh) return { error: 'Sheet not found' };
  const data = sh.getDataRange().getValues();
  const hdrs = data[0];
  const idx  = data.findIndex((r,i) => i > 0 && String(r[0]) === String(id));
  if (idx < 0) return { error: 'Row not found' };
  sh.getRange(idx+1,1,1,hdrs.length).setValues([hdrs.map(h => row[h] !== undefined ? row[h] : '')]);
  return { success: true };
}

function deleteRow(sheetName, id) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(sheetName);
  if (!sh) return { error: 'Sheet not found' };
  const data = sh.getDataRange().getValues();
  const idx  = data.findIndex((r,i) => i > 0 && String(r[0]) === String(id));
  if (idx < 0) return { error: 'Row not found' };
  sh.deleteRow(idx + 1);
  return { success: true };
}`;

/* ═══════════════════════════════════════════════════════════════
   APP STATE
═══════════════════════════════════════════════════════════════ */
const App = {
  gasUrl: localStorage.getItem('gasUrl') || '',
  state: 'setup',
  tab: 'dashboard',
  syncing: false,
  txFilter: 'all',
  txSearch: '',
  masterTab: 'groups',
  editingTx: null,
  editingLedger: null,
  data: {
    transactions: [],
    groups: [],
    categories: [],
    subcategories: [],
    ledgers: []
  }
};

/* ═══════════════════════════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════════════════════════ */
const fmt = n => new Intl.NumberFormat('en-IN',{style:'currency',currency:'INR',maximumFractionDigits:0}).format(n);
const uid = () => Math.random().toString(36).slice(2,10);
const toArr = v => typeof v==='string' ? v.split(',').map(s=>s.trim()).filter(Boolean) : (v||[]);
const esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const svgUp = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>`;
const svgDown = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>`;

function showToast(msg, type='success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast show ${type}`;
  setTimeout(() => t.className = 'toast', 2500);
}

function setSyncing(v) {
  App.syncing = v;
  document.getElementById('syncIndicator').classList.toggle('active', v);
}

/* ═══════════════════════════════════════════════════════════════
   API
═══════════════════════════════════════════════════════════════ */
async function sheetsAPI(url, data) {
  const endpoint = data ? url : `${url}?action=getAll`;
  const opts = data
    ? { method:'POST', headers:{'Content-Type':'text/plain'}, body:JSON.stringify(data), redirect:'follow' }
    : { redirect:'follow' };
  const res = await fetch(endpoint, opts);
  const json = await res.json();
  if (json.error) throw new Error(json.error);
  return json;
}

async function api(action, opts) {
  setSyncing(true);
  try { await sheetsAPI(App.gasUrl, { action, ...opts }); }
  catch(e) { showToast('Sync error: ' + e.message, 'error'); }
  setSyncing(false);
}

/* ═══════════════════════════════════════════════════════════════
   ROUTING / SCREEN CONTROL
═══════════════════════════════════════════════════════════════ */
function showScreen(name) {
  ['setup','loading','error','app'].forEach(s => {
    document.getElementById('screen-'+s).style.display = s===name ? 'block' : 'none';
  });
}

function switchTab(tab) {
  App.tab = tab;
  const titles = {dashboard:'Overview',transactions:'Transactions',ledgers:'Ledgers',settings:'Master Data'};
  document.getElementById('pageTitle').textContent = titles[tab];
  document.querySelectorAll('.nav-item').forEach(el => {
    el.classList.toggle('active', el.dataset.tab === tab);
  });
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-'+tab).classList.add('active');
  renderPage(tab);
}

/* ═══════════════════════════════════════════════════════════════
   DATA LOAD
═══════════════════════════════════════════════════════════════ */
async function loadData(url) {
  showScreen('loading');
  try {
    const d = await sheetsAPI(url);
    App.data.transactions  = d.Transactions  || [];
    App.data.groups        = d.Groups        || [];
    App.data.categories    = d.Categories    || [];
    App.data.subcategories = d.SubCategories || [];
    App.data.ledgers       = d.Ledgers       || [];
    App.gasUrl = url;
    showScreen('app');
    document.getElementById('pageDate').textContent = new Date().toDateString();
    document.getElementById('sheetsStatus').textContent =
      `Google Sheets · ${App.data.transactions.length} entries`;
    renderPage(App.tab);
  } catch(e) { showScreen('error'); }
}

async function connectSheets() {
  const url = document.getElementById('gasUrlInput').value.trim();
  const err = document.getElementById('setup-err');
  const btn = document.getElementById('connectBtn');
  if (!url) return;
  err.style.display = 'none';
  btn.textContent = 'Connecting…';
  btn.disabled = true;
  try {
    const r = await sheetsAPI(url, { action:'init' });
    if (r.success) {
      localStorage.setItem('gasUrl', url);
      await loadData(url);
    } else {
      err.textContent = r.error || 'Init failed. Check your script and permissions.';
      err.style.display = 'block';
    }
  } catch(e) {
    err.textContent = "Cannot reach URL. Ensure Access is set to 'Anyone' in deployment.";
    err.style.display = 'block';
  }
  btn.textContent = 'Connect to Google Sheets';
  btn.disabled = false;
}

function disconnect() {
  localStorage.removeItem('gasUrl');
  App.gasUrl = '';
  App.data = { transactions:[], groups:[], categories:[], subcategories:[], ledgers:[] };
  showScreen('setup');
}

/* ═══════════════════════════════════════════════════════════════
   MODAL
═══════════════════════════════════════════════════════════════ */
function openModal(title, html) {
  document.getElementById('modalTitle').textContent = title;
  document.getElementById('modalBody').innerHTML = html;
  document.getElementById('modal').style.display = 'flex';
