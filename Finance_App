/* ═══════════════════════════════════════════════════════════════
   RENDER DISPATCHER
═══════════════════════════════════════════════════════════════ */
function renderPage(tab) {
  if (tab === 'dashboard')    renderDashboard();
  if (tab === 'transactions') renderTransactions();
  if (tab === 'ledgers')      renderLedgers();
  if (tab === 'settings')     renderSettings();
}

/* ═══════════════════════════════════════════════════════════════
   MONTHLY DATA
═══════════════════════════════════════════════════════════════ */
function getMonthly(txs) {
  const map = {};
  txs.forEach(t => {
    const k = t.date.slice(0,7);
    if (!map[k]) map[k] = {income:0,expense:0};
    if (t.type==='income') map[k].income += +t.amount;
    else map[k].expense += +t.amount;
  });
  return Object.entries(map).sort().map(([m,v]) => ({month:m,...v,profit:v.income-v.expense}));
}

/* ═══════════════════════════════════════════════════════════════
   DASHBOARD
═══════════════════════════════════════════════════════════════ */
function renderDashboard() {
  const { transactions, categories } = App.data;
  const totalInc = transactions.filter(t=>t.type==='income').reduce((a,t)=>a+(+t.amount),0);
  const totalExp = transactions.filter(t=>t.type==='expense').reduce((a,t)=>a+(+t.amount),0);
  const net = totalInc - totalExp;
  const mo = new Date().toISOString().slice(0,7);
  const mTx = transactions.filter(t=>t.date.slice(0,7)===mo);
  const mInc = mTx.filter(t=>t.type==='income').reduce((a,t)=>a+(+t.amount),0);
  const mExp = mTx.filter(t=>t.type==='expense').reduce((a,t)=>a+(+t.amount),0);
  const mData = getMonthly(transactions);
  const catBrk = categories.map(c=>({...c,total:mTx.filter(t=>t.categoryId===c.id).reduce((a,t)=>a+(+t.amount),0)})).filter(c=>c.total>0).sort((a,b)=>b.total-a.total).slice(0,5);
  const maxC = Math.max(...catBrk.map(c=>c.total),1);

  // Bar chart HTML
  let chartHtml = '<p style="color:var(--muted);font-size:13px;text-align:center;padding:16px 0">Add transactions to see chart</p>';
  if (mData.length) {
    const max = Math.max(...mData.map(d=>Math.max(d.income,d.expense)),1);
    chartHtml = '<div class="chart-wrap">' + mData.slice(-6).map(d => `
      <div class="chart-col">
        <div class="chart-bars">
          <div class="bar" style="background:var(--green);height:${(d.income/max)*56}px"></div>
          <div class="bar" style="background:var(--red);height:${(d.expense/max)*56}px"></div>
        </div>
        <span class="chart-label">${d.month.slice(5)}</span>
      </div>`).join('') + '</div>';
  }

  // P&L table
  let tableHtml = '<p style="color:var(--muted);font-size:13px;text-align:center;padding:12px 0">No data yet</p>';
  if (mData.length) {
    tableHtml = `<table class="data-table">
      <thead><tr><th>Month</th><th class="r">Income</th><th class="r">Expense</th><th class="r">P&L</th></tr></thead>
      <tbody>${mData.slice(-6).reverse().map(r=>`
        <tr>
          <td style="color:#94a3b8">${r.month}</td>
          <td class="r" style="color:var(--green)">${fmt(r.income)}</td>
          <td class="r" style="color:var(--red)">${fmt(r.expense)}</td>
          <td class="r" style="color:${r.profit>=0?'var(--green)':'var(--red)'};font-weight:700">${r.profit>=0?'+':''}${fmt(r.profit)}</td>
        </tr>`).join('')}
      </tbody>
    </table>`;
  }

  // Category bars
  let catHtml = '';
  catBrk.forEach(c => {
    catHtml += `<div style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;margin-bottom:5px">
        <span style="font-size:13px;color:#CBD5E1">${esc(c.name)}</span>
        <span style="font-size:13px;font-weight:700;color:var(--text);font-family:var(--font-mono)">${fmt(c.total)}</span>
      </div>
      <div class="prog-track"><div class="prog-fill" style="width:${(c.total/maxC)*100}%"></div></div>
    </div>`;
  });

  document.getElementById('page-dashboard').innerHTML = `
    <!-- Hero -->
    <div class="hero-card">
      <div class="hero-label">Net P&L — All Time</div>
      <div class="hero-amount" style="color:${net>=0?'var(--green)':'var(--red)'}">${net>=0?'+':''}${fmt(net)}</div>
      <div class="hero-row">
        <div>
          <div class="hero-stat-label" style="color:var(--green)">Total Income</div>
          <div class="hero-stat-val">${fmt(totalInc)}</div>
        </div>
        <div>
          <div class="hero-stat-label" style="color:var(--red)">Total Expense</div>
          <div class="hero-stat-val">${fmt(totalExp)}</div>
        </div>
      </div>
    </div>

    <!-- Month cards -->
    <div class="grid2">
      <div class="stat-card" style="background:var(--green-dim);border-color:rgba(45,212,160,0.2)">
        <div style="color:var(--green)">${svgUp}</div>
        <div class="stat-card-label">Income · Month</div>
        <div class="stat-card-val" style="color:var(--green)">${fmt(mInc)}</div>
      </div>
      <div class="stat-card" style="background:var(--red-dim);border-color:rgba(244,113,106,0.2)">
        <div style="color:var(--red)">${svgDown}</div>
        <div class="stat-card-label">Expense · Month</div>
        <div class="stat-card-val" style="color:var(--red)">${fmt(mExp)}</div>
      </div>
    </div>

    <!-- Bar chart -->
